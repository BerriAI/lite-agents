# Required.
LITELLM_API_BASE=http://0.0.0.0:4000
LITELLM_API_KEY=sk-1234
LITELLM_MODEL=claude-sonnet-4-6

# Required. Stable id for this agent. Prefixes every memory key on the
# LiteLLM proxy so multiple agents sharing one proxy don't collide.
# Pick a short lowercase id and keep it stable across deploys.
AGENT_ID=agent

# Optional. Comma-separated list of MCP server ids that the LiteLLM proxy
# fronts at /mcp/<id>. Empty = no MCP toolsets.
# MCP_SERVERS=circleci,github

# Optional. Chat UI admin login. When BOTH are set, the UI at /
# requires HTTP basic auth. Same credentials are also accepted on
# /v1/chat/completions, so the UI's own calls work without separate
# bearer setup. Leave UNSET for an open UI (dev only).
# UI_USERNAME=admin
# UI_PASSWORD=changeme

# Optional. Comma-separated bearer keys for /v1/chat/completions.
# AGENT_API_KEYS=sk-local-1

# Optional. Set ENABLE_TASKS=1 + DATABASE_URL to expose
# schedule/list_tasks/cancel tools backed by a Postgres dispatcher
# (atomic across multiple agent replicas via FOR UPDATE SKIP LOCKED).
# Apply migrations/001_tasks.sql once before first run.
# ENABLE_TASKS=1
# DATABASE_URL=postgresql://agent:agent@localhost:5432/agent
# (For docker-compose, the bundled value is postgresql://agent:agent@db:5432/agent)

# Optional. OpenTelemetry — set the endpoint and traces flow.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com:4318
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer xyz
# OTEL_SERVICE_NAME=agent

# Optional.
# HOST=0.0.0.0
# PORT=8787
# LOG_LEVEL=INFO
